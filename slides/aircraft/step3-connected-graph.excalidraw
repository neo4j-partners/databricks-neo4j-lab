      "updated": 1739750000000,
      "link": null,
      "locked": false,
      "text": "MATCH (a:Aircraft {tail_number:'N95040A'})\n  -[:HAS_SYSTEM]->(s)\n  -[:HAS_COMPONENT]->(c)\nRETURN a, s, c",
