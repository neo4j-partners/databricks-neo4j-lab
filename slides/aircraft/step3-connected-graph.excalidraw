      "updated": 1739750000000,
      "link": null,
      "locked": false,
      "text": "SELECT * FROM aircraft a\n  JOIN systems s ON a.id = s.aircraft_id\n  JOIN components c ON s.id = c.system_id\n  WHERE a.tail_number = 'N95040A'",
      "originalText": "SELECT * FROM aircraft a\n  JOIN systems s ON a.id = s.aircraft_id\n  JOIN components c ON s.id = c.system_id\n  WHERE a.tail_number = 'N95040A'",
